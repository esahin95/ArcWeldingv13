FoamFile
{
    format      ascii;
    class       dictionary;
    location    "constant";
    object      fvModels;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

laser
{
    type            laserDTRM;

    phase           gas;

    position table
    (
        (  0 ( 40e-6 50e-6 150e-6))
        (100e-6 (110e-6 50e-6 150e-6))
    );

    normal          (0.0 0.0 -1.0);

    Q               1.0;

    nRays           300;

    relax           0.7;

    radius          10e-6;

    absorption      1e+6;

    reflectionModel
    {
        type fresnelLaser;
        epsilon 0.2;
    };

    powerDist       constant 1;

    setFormat       vtk;
}

