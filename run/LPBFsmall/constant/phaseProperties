FoamFile
{
    format      ascii;
    class       dictionary;
    location    "constant";
    object      phaseProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

phases          (metal gas);


sigma
{
  type  temperatureDependent;
  sigma // 0.07 - dT * 5e-5
  {
    type    table;
    values
    (
        (1658 0.07)
        (3058 0.00)
    );
    outOfBounds         clamp;
    interpolationScheme linear;
  }
}

