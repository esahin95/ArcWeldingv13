FoamFile
{
    format      ascii;
    class       dictionary;
    location    "constant";
    object      physicalProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

viscosityModel  Newtonian;

nu              1.3834e-04;

rho             1.6337;

thermoModel     Simple;

Cp              520;

kappa           0.0177;

beta            0;


// ************************************************************************* //

