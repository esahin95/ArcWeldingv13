FoamFile
{
    format      ascii;
    class       dictionary;
    location    "constant";
    object      physicalProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

thermoType
{
    type            heRhoThermo;
    mixture         pureMixture;
    transport       const;
    thermo          hConst;
    equationOfState rhoConst;
    specie          specie;
    energy          sensibleEnthalpy;
}

mixture
{
    specie
    {
        molWeight   28.9;
    }

    equationOfState
    {
        rho         1.6337;
    }

    thermodynamics
    {
        Cp          520;
        hf          0;
    }
    
    transport
    {
        mu          2.2601e-04;
        kappa       0.0177;
    }
}


