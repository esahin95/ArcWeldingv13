FoamFile
{
    format      ascii;
    class       dictionary;
    location    "constant";
    object      physicalProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

viscosityModel  Newtonian;

nu              1.636e-07;

rho             9780.0;

thermoModel     Simple;

Cp              123;

kappa           10.35;

beta            0;


// ************************************************************************* //
