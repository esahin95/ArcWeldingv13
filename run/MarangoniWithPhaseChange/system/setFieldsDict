FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      setFieldsDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

defaultValues
{
    alpha.bismuth 0;
};

zones
{
    metalPlate
    {
        type        box;
        zoneType    cell;
        box (-1 -1 -1) (1 0.004 1);
        values
        {
            alpha.bismuth   1;
        }
    }
};

