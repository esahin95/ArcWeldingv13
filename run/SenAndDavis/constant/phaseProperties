FoamFile
{
    format      ascii;
    class       dictionary;
    location    "constant";
    object      phaseProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

phases          ( water air );


sigma
{
  type  temperatureDependent;
  sigma
  {
    type    table;
    values
    (
        (200 0.02)
        (400 0.0)
    );
    outOfBounds         clamp;
    interpolationScheme linear;
  }
}

L           0;
Cu          0;
alphaSolidT
{
    type    errorFunction;
    Tliq    302.0;
    Tsol    298.0;
}

