FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     foamRun;

solver          incompressibleThermoVoF;

startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         0.05;

deltaT          1e-5;

writeControl    adjustableRunTime;

writeInterval   0.005;

purgeWrite      0;

writeFormat     binary;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable yes;

adjustTimeStep  yes;

maxCo           0.5;
maxAlphaCo      0.5;

maxDeltaT       5e-5;

libs
(
    "liberrorFunction1.so"
);

DebugSwitches
{
    MULES           1;
}


// ************************************************************************* //

OptimisationSwitches
{
    fileHandler collated;
}

functions
{
    residuals
    {
        type            residuals;

        libs            ("libutilityFunctionObjects.so");

        writeControl    timeStep;
        writeInterval   1;

        fields          (p_rgh);
    }

    divU
    {
        type            div;
        libs            ("libfieldFunctionObjects.so");

        writeControl    writeTime;
        writeFields     true;
        regionType      all;

        result          divU;

        field           phi;
    }

    maxValue
    {
        type            volFieldValue;

        libs            ("libfieldFunctionObjects.so");

        log             true;

        writeControl    writeTime;

        writeFields     false;

        regionType      all;

        cellZone        all;

        operation       maxMag;

        fields (p_rgh U T divU);
    }
  
    lineUniform
    {
        type            sets;

        libs            ("libsampling.so");

        writeControl    writeTime;

        interpolationScheme cellPoint;

        setFormat       raw;

        fields          (alpha.water);

        sets
        (
            left
            {
                type            lineUniform;
                axis            distance;
                start           (1e-7 0.0 5e-5);
                end             (1e-7 5e-4 5e-5);
                nPoints         120;
            }

            right
            {
                type            lineUniform;
                axis            distance;
                start           (0.9999e-3 0.0 5e-5);
                end             (0.9999e-3 5e-4 5e-5);
                nPoints         120;
            }
        );
    }
}