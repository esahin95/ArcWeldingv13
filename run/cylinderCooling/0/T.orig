FoamFile
{
    format      ascii;
    class       volScalarField;
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 1 0 0 0];

Tinlet  300;
Twall   400;

internalField   uniform 300;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform $Tinlet;
    }

    outlet
    {
        type            inletOutlet;
        inletValue      uniform $Tinlet;
        value           uniform $Tinlet;
    }

    wall
    {
        type            lumpedMassTemperature;
        rho             1000;
        Cv              1300;
        T               $Twall;
        Q               constant 0;
        value           uniform $T;
    }

    #includeEtc "caseDicts/setConstraintTypes"
}

// ************************************************************************* //
